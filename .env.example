# Inquiry form delivery (Resend). Copy to .env.local for local dev, and add
# the same keys in your Vercel project → Settings → Environment Variables.

# Required. Create one at https://resend.com/api-keys
RESEND_API_KEY=

# Optional. Where inquiries are delivered. Defaults to SITE.email in src/lib/data.ts.
INQUIRY_TO=

# Optional. The "from" address. Must be a verified Resend sender/domain.
# Defaults to Resend's shared test sender, which works before you verify a domain.
INQUIRY_FROM=Ganga Group <onboarding@resend.dev>
